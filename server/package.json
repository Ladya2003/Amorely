{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend for Amorely",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:local": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "debug": "node --inspect-brk -r ts-node/register src/index.ts",
    "setup": "node setup-dev.js",
    "db:start": "docker-compose -f ../docker-compose.dev.yml up -d",
    "db:stop": "docker-compose -f ../docker-compose.dev.yml down",
    "db:restart": "docker-compose -f ../docker-compose.dev.yml restart",
    "db:logs": "docker-compose -f ../docker-compose.dev.yml logs -f mongodb",
    "db:reset": "docker-compose -f ../docker-compose.dev.yml down -v && docker-compose -f ../docker-compose.dev.yml up -d",
    "db:start:native": "net start MongoDB",
    "db:stop:native": "net stop MongoDB",
    "db:status:native": "net start MongoDB && mongo --eval \"db.adminCommand('ismaster')\"",
    "db:reset:native": "net stop MongoDB && rmdir /s /q C:\\data\\db && net start MongoDB",
    "compass": "start \"\" \"C:\\Program Files\\MongoDB\\Tools\\100\\bin\\MongoDBCompass.exe\"",
    "compass:connect": "start \"\" \"C:\\Program Files\\MongoDB\\Tools\\100\\bin\\MongoDBCompass.exe\" --uri mongodb://localhost:27017",
    "seed:beta-news": "ts-node scripts/seed-beta-news.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/socket.io": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.4",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2"
  }
}
