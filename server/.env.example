# URL фронта. Для GitHub Pages можно с путём или только origin — CORS берёт origin в любом случае.
# Вариант A (как на проде):
CLIENT_URL=https://ladya2003.github.io/Amorely
APP_BASE_PATH=
# Вариант B (эквивалентно): CLIENT_URL=https://ladya2003.github.io и APP_BASE_PATH=/Amorely
MONGODB_URI=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Web Push (PWA): npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@amorely.app
# Секрет для внешнего cron (например Render). Заголовок x-cron-secret или ?secret=
CRON_SECRET=
