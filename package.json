{
  "name": "amorely",
  "version": "1.0.0",
  "description": "Amorely full-stack application",
  "scripts": {
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-client": "cd client && npm install",
    "install-server": "cd server && npm install",
    "install-all": "npm install && npm run install-client && npm run install-server",
    "pets:copy-images": "node scripts/copy-pet-images.mjs",
    "pets:optimize-images": "node scripts/optimize-pet-images.mjs",
    "pets:generate-images": "node scripts/generate-pet-images.mjs",
    "pets:generate-images:dry": "node scripts/generate-pet-images.mjs --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sharp": "^0.35.2"
  }
}
